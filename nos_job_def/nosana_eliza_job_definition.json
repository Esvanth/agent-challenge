{
  "ops": [
    {
      "id": "run-mindtune-agent",
      "args": {
        "cmd": ["node", "dist/index.js"],
        "gpu": false,
        "image": "docker.io/esvanth7/mindtune-eliza:latest",
        "expose": 3000,
        "env": {
          "GROQ_API_KEY": "your_groq_api_key_here",
          "GROQ_LARGE_MODEL": "llama-3.3-70b-versatile",
          "LARGE_GROQ_MODEL": "llama-3.3-70b-versatile",
          "PORT": "3000"
        }
      },
      "type": "container/run"
    }
  ],
  "meta": {
    "trigger": "dashboard"
  },
  "type": "container",
  "version": "0.1"
}
